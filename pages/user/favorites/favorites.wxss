/* 我的收藏页 */
.container-safe {
  padding: 0 32rpx 48rpx;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  margin-bottom: 24rpx;
}

.nav-back {
  width: 80rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
}

.nav-icon {
  font-size: 40rpx;
  color: var(--primary-900);
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 36rpx;
  font-weight: 500;
  color: var(--primary-900);
}

.nav-edit {
  width: 100rpx;
  text-align: right;
}

.edit-text {
  font-size: 28rpx;
  color: var(--accent-600);
}

/* 收藏列表 */
.favorites-list {
  margin-bottom: 120rpx;
}

.favorite-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: var(--radius-lg);
  padding: 32rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.favorite-item.selected {
  background: var(--accent-100);
}

.select-box {
  margin-right: 24rpx;
}

.select-circle {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid var(--primary-200);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #fff;
  transition: all 0.2s;
}

.select-circle.checked {
  background: var(--accent-600);
  border-color: var(--accent-600);
}

.item-content {
  flex: 1;
}

.item-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.item-name {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--primary-900);
}

.item-score {
  font-size: 32rpx;
  font-weight: bold;
}

.item-info {
  margin-bottom: 12rpx;
}

.info-item {
  font-size: 26rpx;
  color: var(--primary-500);
}

.item-quote {
  padding: 12rpx;
  background: var(--primary-50);
  border-radius: var(--radius-sm);
}

.item-quote text {
  font-size: 26rpx;
  color: var(--primary-700);
  font-style: italic;
}

.item-arrow {
  font-size: 32rpx;
  color: var(--primary-500);
  margin-left: 16rpx;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 32rpx;
}

.load-more text {
  font-size: 28rpx;
  color: var(--accent-600);
}

/* 编辑模式底部操作 */
.edit-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.select-all {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: var(--primary-700);
}

.select-all .select-circle {
  margin-right: 12rpx;
}

.compare-btn {
  margin: 0 24rpx;
}

.delete-btn {
  background: #ff4d4f;
  color: #fff;
  padding: 0 48rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: var(--radius-full);
  font-size: 28rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 64rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
  opacity: 0.3;
}

.empty-title {
  font-size: 32rpx;
  color: var(--primary-700);
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: var(--primary-500);
  margin-bottom: 48rpx;
}

.go-btn {
  width: 280rpx;
}
