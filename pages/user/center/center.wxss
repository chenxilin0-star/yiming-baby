/* 个人中心页 - 优化版 */
.page-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 48rpx;
}

/* 用户信息卡 */
.user-card {
  position: relative;
  background: linear-gradient(135deg, #c45c48 0%, #d67a6a 100%);
  padding: 120rpx 48rpx 80rpx;
  border-radius: 0 0 48rpx 48rpx;
  overflow: hidden;
}

.user-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  overflow: hidden;
}

.bg-circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
}

.circle-1 {
  width: 400rpx;
  height: 400rpx;
  top: -200rpx;
  right: -100rpx;
}

.circle-2 {
  width: 300rpx;
  height: 300rpx;
  bottom: -100rpx;
  left: -50rpx;
}

.user-content {
  position: relative;
  z-index: 1;
}

/* 未登录状态 */
.user-info-unauthorized {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-placeholder {
  width: 160rpx;
  height: 160rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.placeholder-icon {
  font-size: 80rpx;
}

.unauthorized-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 24rpx;
}

.auth-btn {
  padding: 20rpx 64rpx !important;
  background: #fff !important;
  border-radius: 40rpx !important;
  font-size: 30rpx !important;
  color: #c45c48 !important;
  font-weight: 500 !important;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15) !important;
  border: none !important;
  line-height: 1.5 !important;
  margin: 0 !important;
}

.auth-btn::after {
  border: none !important;
}

/* 已登录状态 */
.user-info {
  display: flex;
  align-items: center;
}

.avatar-wrap {
  position: relative;
  margin-right: 32rpx;
}

.user-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  background: #fff;
}

.avatar-badge {
  position: absolute;
  bottom: 8rpx;
  right: 8rpx;
  width: 36rpx;
  height: 36rpx;
  background: #52c41a;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #c45c48;
}

.badge-icon {
  font-size: 20rpx;
  color: #fff;
}

.user-meta {
  flex: 1;
}

.user-name {
  display: block;
  font-size: 44rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 12rpx;
}

.user-id {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 服务统计 */
.stats-section {
  margin: -40rpx 32rpx 32rpx;
  position: relative;
  z-index: 10;
}

.stats-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx 0;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.stat-icon-wrap.blue {
  background: #e6f7ff;
}

.stat-icon-wrap.orange {
  background: #fff7e6;
}

.stat-icon-wrap.green {
  background: #f6ffed;
}

.stat-icon {
  font-size: 40rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.stat-name {
  font-size: 26rpx;
  color: #8a8a8a;
}

.stat-divider {
  width: 2rpx;
  height: 80rpx;
  background: #f0f0f0;
}

/* VIP区域 */
.vip-section {
  margin: 0 32rpx 32rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 20rpx;
  padding-left: 8rpx;
}

.vip-list {
  background: #fff;
  border-radius: 24rpx;
  padding: 8rpx 0;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.vip-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.vip-item:last-child {
  border-bottom: none;
}

.vip-item:active {
  background: #fafafa;
}

.vip-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.vip-icon-wrap.vip-gold {
  background: linear-gradient(135deg, #fff7e6, #fff);
}

.vip-icon-wrap.vip-blue {
  background: linear-gradient(135deg, #e6f7ff, #fff);
}

.vip-icon {
  font-size: 36rpx;
}

.vip-info {
  flex: 1;
}

.vip-name {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.vip-desc {
  display: block;
  font-size: 24rpx;
  color: #8a8a8a;
}

.vip-tag {
  padding: 8rpx 16rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 22rpx;
  color: #8a8a8a;
  margin-right: 16rpx;
}

.arrow {
  font-size: 32rpx;
  color: #c0c0c0;
}

/* 菜单列表 */
.menu-section {
  margin: 0 32rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 8rpx 0;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #fafafa;
}

.menu-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.menu-icon {
  font-size: 32rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #1a1a1a;
}

.menu-arrow {
  font-size: 32rpx;
  color: #c0c0c0;
}

/* 版本号 */
.version-section {
  text-align: center;
  padding: 48rpx 0;
}

.version-text {
  font-size: 24rpx;
  color: #c0c0c0;
}

/* 授权弹窗 */
.auth-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 48rpx 32rpx 40rpx;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.modal-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.modal-body {
  margin-bottom: 40rpx;
}

.avatar-section,
.nickname-section {
  margin-bottom: 32rpx;
}

.section-label {
  display: block;
  font-size: 28rpx;
  color: #1a1a1a;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.avatar-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 !important;
  background: transparent !important;
  border: none !important;
}

.avatar-btn::after {
  border: none !important;
}

.avatar-preview {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #f5f5f5;
  margin-bottom: 16rpx;
  border: 4rpx solid #f0f0f0;
}

.avatar-tip {
  font-size: 24rpx;
  color: #8a8a8a;
}

.nickname-input {
  width: 100%;
  padding: 28rpx 32rpx;
  background: #fff;
  border: 2rpx solid #e8e8e8;
  border-radius: 20rpx;
  font-size: 30rpx;
  color: #1a1a1a;
  box-sizing: border-box;
  transition: all 0.3s ease;
}

.nickname-input:focus {
  border-color: #c45c48;
  background: #fffbfb;
}

.modal-footer {
  display: flex;
  gap: 16rpx;
}

.modal-btn {
  flex: 1;
  padding: 24rpx !important;
  border-radius: 16rpx !important;
  font-size: 30rpx !important;
  font-weight: 500 !important;
  border: none !important;
  margin: 0 !important;
}

.modal-btn::after {
  border: none !important;
}

.cancel-btn {
  background: #f5f5f5 !important;
  color: #8a8a8a !important;
}

.confirm-btn {
  background: linear-gradient(135deg, #c45c48, #d67a6a) !important;
  color: #fff !important;
}
