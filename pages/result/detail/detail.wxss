/* 名字详情页 */
.container-safe {
  padding: 0 32rpx 48rpx;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  margin-bottom: 24rpx;
}

.nav-back {
  width: 80rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
}

.nav-icon {
  font-size: 40rpx;
  color: var(--primary-900);
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 36rpx;
  font-weight: 500;
  color: var(--primary-900);
}

.nav-favorite {
  width: 80rpx;
  text-align: right;
}

.favorite-icon {
  font-size: 48rpx;
  color: var(--primary-200);
}

.favorite-icon.active {
  color: var(--accent-600);
}

/* 名字主展示 */
.name-hero {
  text-align: center;
  padding: 48rpx 32rpx;
  background: linear-gradient(180deg, #fff 0%, #fafafa 100%);
  border-radius: var(--radius-lg);
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.name-text {
  display: block;
  font-size: 80rpx;
  font-weight: bold;
  color: var(--primary-900);
  margin-bottom: 16rpx;
}

.name-divider {
  width: 120rpx;
  height: 4rpx;
  background: var(--accent-600);
  margin: 0 auto 24rpx;
}

.score-section {
  margin-bottom: 24rpx;
}

.score-label {
  font-size: 28rpx;
  color: var(--primary-500);
  margin-right: 12rpx;
}

.score-value {
  font-size: 56rpx;
  font-weight: bold;
}

.score-unit {
  font-size: 28rpx;
  color: var(--primary-500);
}

.name-tags {
  display: flex;
  justify-content: center;
  gap: 16rpx;
}

.tag {
  padding: 8rpx 24rpx;
  background: var(--primary-50);
  border-radius: var(--radius-full);
  font-size: 24rpx;
  color: var(--primary-500);
}

.tag-primary {
  background: var(--accent-100);
  color: var(--accent-600);
}

/* 卡片通用样式 */
.card {
  background: #fff;
  border-radius: var(--radius-lg);
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.card-title {
  display: block;
  font-size: 32rpx;
  font-weight: 500;
  color: var(--primary-900);
  margin-bottom: 24rpx;
}

/* 单字解析 */
.char-card {
  background: var(--primary-50);
  border-radius: var(--radius-md);
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.char-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  flex-wrap: wrap;
}

.char-name {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--primary-900);
  margin-right: 16rpx;
}

.char-meta {
  font-size: 26rpx;
  color: var(--primary-500);
  margin-right: 16rpx;
}

.wuxing-badge {
  padding: 4rpx 16rpx;
  border-radius: var(--radius-full);
  font-size: 24rpx;
  color: #fff;
}

.char-body {
  padding-top: 16rpx;
  border-top: 2rpx solid var(--primary-200);
}

.meaning-label, .source-label {
  font-size: 26rpx;
  color: var(--primary-500);
}

.meaning-text, .source-text {
  display: block;
  font-size: 28rpx;
  color: var(--primary-700);
  margin-bottom: 12rpx;
}

/* 音律分析 */
.yinylv-section {
  text-align: center;
}

.pinyin-row {
  display: flex;
  justify-content: center;
  gap: 48rpx;
  margin-bottom: 24rpx;
}

.pinyin-item {
  font-size: 36rpx;
  color: var(--primary-900);
}

.shengdiao-row, .yunmu-row {
  margin-bottom: 16rpx;
}

.shengdiao-label, .yunmu-label {
  font-size: 28rpx;
  color: var(--primary-500);
}

.shengdiao-value, .yunmu-value {
  font-size: 28rpx;
  color: var(--primary-700);
}

.play-btn {
  display: inline-flex;
  align-items: center;
  padding: 16rpx 32rpx;
  background: var(--accent-100);
  border-radius: var(--radius-full);
  margin-top: 16rpx;
}

.play-icon {
  font-size: 28rpx;
  color: var(--accent-600);
  margin-right: 12rpx;
}

.play-text {
  font-size: 28rpx;
  color: var(--accent-600);
}

/* 诗词典故 */
.gua-header {
  background: linear-gradient(135deg, #f5f5f5, #fff);
  padding: 24rpx;
  border-radius: var(--radius-md);
  margin-bottom: 16rpx;
}

.gua-name {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: var(--primary-900);
  margin-bottom: 8rpx;
}

.gua-yao {
  display: block;
  font-size: 26rpx;
  color: var(--primary-500);
  font-style: italic;
}

.gua-meaning {
  padding: 16rpx;
}

.meaning-item {
  display: block;
  font-size: 28rpx;
  color: var(--primary-700);
  margin-bottom: 12rpx;
}

/* 现代寓意 */
.modern-meaning {
  font-size: 30rpx;
  color: var(--primary-700);
  line-height: 1.8;
}

/* 三才五格 */
.wuge-section {
  padding: 16rpx;
}

.wuge-row {
  display: flex;
  gap: 24rpx;
  margin-bottom: 16rpx;
}

.wuge-row.total {
  justify-content: center;
  padding-top: 16rpx;
  border-top: 2rpx solid var(--primary-200);
}

.wuge-item {
  flex: 1;
  display: flex;
  align-items: center;
  padding: 16rpx;
  background: var(--primary-50);
  border-radius: var(--radius-md);
}

.wuge-name {
  font-size: 28rpx;
  color: var(--primary-500);
  margin-right: 12rpx;
}

.wuge-value {
  flex: 1;
  font-size: 28rpx;
  color: var(--primary-700);
}

.wuge-jixiong {
  padding: 4rpx 12rpx;
  border-radius: var(--radius-sm);
  font-size: 24rpx;
}

.wuge-jixiong.ji {
  background: #f6ffed;
  color: #52c41a;
}

.wuge-jixiong.xiong {
  background: var(--primary-50);
  color: var(--primary-500);
}

.wuge-hint {
  display: block;
  text-align: center;
  font-size: 26rpx;
  color: var(--primary-500);
  margin-top: 16rpx;
}

/* 底部操作 */
.footer-actions {
  margin-top: 48rpx;
  text-align: center;
}

.favorite-btn, .share-btn {
  margin-bottom: 24rpx;
}

.regenerate-btn {
  margin-top: 16rpx;
}
