/* 名字分析结果页样式 */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 32rpx;
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
}

.nav-icon {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.nav-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.nav-action {
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  color: #f0f5ff;
}

.nav-text {
  font-size: 28rpx;
  color: #f0f5ff;
}

/* 名字卡片 */
.name-card {
  margin: 32rpx;
  padding: 48rpx 32rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(240, 0, 85, 0.08);
}

.name-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.name-main {
  font-size: 56rpx;
  font-weight: bold;
  color: #333;
}

.score-badge {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  border-radius: 50rpx;
  background: linear-gradient(135deg, #f0f5ff, #fff0f5);
}

.score-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
}

.score-unit {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-left: 8rpx;
}

.name-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.info-tag {
  padding: 8rpx 16rpx;
  background: #f0f5ff;
  color: #fff;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.info-divider {
  color: #999;
}

.info-text {
  font-size: 28rpx;
  color: #666;
}

/* 区域卡片 */
.section-card {
  margin: 32rpx;
  padding: 32rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(240, 0, 85, 0.06);
}

.section-header {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

/* 生辰网格 */
.bazi-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.bazi-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
}

.bazi-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.bazi-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.bazi-wuxing {
  font-size: 24rpx;
  color: #666;
  padding: 4rpx 12rpx;
  background: #f0f5ff;
  border-radius: 8rpx;
}

.bazi-footer {
  display: flex;
  justify-content: space-between;
  font-size: 28rpx;
  color: #666;
}

.footer-label {
  color: #999;
}

.footer-value {
  color: #333;
  font-weight: 500;
}

/* 五行图表 */
.wuxing-chart {
  margin-bottom: 32rpx;
}

.chart-item {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.chart-label {
  width: 80rpx;
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
}

.chart-bar {
  flex: 1;
  height: 32rpx;
  background: #f0f0f0;
  border-radius: 16rpx;
  overflow: hidden;
  margin: 0 16rpx;
}

.bar-fill.gold {
  height: 100%;
  background: #e6c3c3;
  transition: width 0.5s ease;
}

.bar-fill.wood {
  height: 100%;
  background: #52c41a;
  transition: width 0.5s ease;
}

.bar-fill.water {
  height: 100%;
  background: #4a90d9;
  transition: width 0.5s ease;
}

.bar-fill.fire {
  height: 100%;
  background: #d4af37;
  transition: width 0.5s ease;
}

.bar-fill.earth {
  height: 100%;
  background: #8a8a8a;
  transition: width 0.5s ease;
}

.chart-value {
  width: 60rpx;
  text-align: right;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.wuxing-summary {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.wuxing-summary.good {
  background: #d4af37;
  color: #fff;
}

.wuxing-summary.warning {
  background: #ff9800;
  color: #fff;
}

.wuxing-summary.danger {
  background: #dc3545;
  color: #fff;
}

.summary-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.summary-text {
  font-size: 28rpx;
  font-weight: 500;
  flex: 1;
}

.advice-list {
  margin-top: 16rpx;
}

.advice-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}

/* 五格网格 */
.wuge-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.wuge-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
  border: 3rpx solid #e5e5e5;
}

.wuge-item.lucky {
  border-color: #d4af37;
  background: rgba(212, 175, 55, 0.05);
}

.wuge-item.unlucky {
  border-color: #dc3545;
  background: rgba(220, 53, 69, 0.05);
}

.wuge-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.wuge-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.wuge-wuxing {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.wuge-jixiong {
  font-size: 24rpx;
  font-weight: 500;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.wuge-item.lucky .wuge-jixiong {
  background: #d4af37;
  color: #fff;
}

.wuge-item.unlucky .wuge-jixiong {
  background: #dc3545;
  color: #fff;
}

/* 建议列表 */
.section-card.suggestions {
  background: #fffbeb0;
}

.suggestion-list {
  margin-top: 24rpx;
}

.suggestion-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.suggestion-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.suggestion-text {
  flex: 1;
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}

/* 底部操作 */
.footer-actions {
  display: flex;
  gap: 24rpx;
  padding: 32rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
}

.action-btn.primary {
  background: #f0f5ff;
  color: #fff;
}

.action-btn.secondary {
  background: #fff;
  color: #f0f5ff;
  border: 2rpx solid #f0f5ff;
}
