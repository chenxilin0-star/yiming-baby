/* 名字分析表单页样式 */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #f0f5ff 0%, #fff0f5 100%);
  padding-bottom: 40rpx;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 32rpx;
  background: #fff;
}

.nav-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.nav-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.nav-placeholder {
  width: 60rpx;
}

/* 表单卡片 */
.form-card {
  margin: 32rpx;
  padding: 48rpx 32rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(240, 0, 85, 0.08);
}

.card-header {
  text-align: center;
  margin-bottom: 48rpx;
}

.card-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
}

.card-subtitle {
  font-size: 28rpx;
  color: #999;
}

/* 表单区域 */
.form-section {
  margin-bottom: 40rpx;
}

.form-label {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  display: block;
  margin-bottom: 24rpx;
}

/* 名字输入 */
.name-input-row {
  display: flex;
  gap: 24rpx;
}

.name-input {
  flex: 1;
  height: 88rpx;
  padding: 0 24rpx;
  border: 2rpx solid #e5e5e5;
  border-radius: 12rpx;
  font-size: 32rpx;
  background: #f9f9f9;
}

.name-input.main-name {
  flex: 2;
}

.form-hint {
  font-size: 24rpx;
  color: #999;
  margin-top: 16rpx;
  display: block;
}

/* 日期时间选择 */
.date-picker-row,
.time-picker-row {
  margin-bottom: 24rpx;
}

.picker-display {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 24rpx;
  border: 2rpx solid #e5e5e5;
  border-radius: 12rpx;
  background: #f9f9f9;
}

.picker-label {
  font-size: 28rpx;
  color: #666;
}

.picker-value {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

/* 性别选择 */
.gender-row {
  display: flex;
  gap: 24rpx;
}

.gender-option {
  flex: 1;
  height: 120rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 3rpx solid #e5e5e5;
  border-radius: 16rpx;
  background: #f9f9f9;
  transition: all 0.3s;
}

.gender-option.active {
  border-color: #4a90e2;
  background: #e6f0ff;
  box-shadow: 0 4rpx 12rpx rgba(74, 144, 226, 0.2);
}

.gender-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.gender-label {
  font-size: 28rpx;
  color: #333;
}

.gender-option.active .gender-label {
  color: #4a90e2;
  font-weight: bold;
}

/* 提交区域 */
.submit-section {
  margin-top: 48rpx;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
  border: none;
  border-radius: 16rpx;
}

.submit-btn[disabled] {
  background: #ccc;
}

.submit-hint {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  margin-top: 24rpx;
  display: block;
}

/* 说明卡片 */
.info-card {
  margin: 32rpx;
  padding: 32rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 16rpx;
}

.info-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 32rpx;
}

.info-item:last-child {
  margin-bottom: 0;
}

.info-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.info-content {
  flex: 1;
}

.info-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  display: block;
  margin-bottom: 8rpx;
}

.info-desc {
  font-size: 24rpx;
  color: #666;
}
