/* 步骤一：基础信息 - 优化版 */
.page-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #faf8f5 0%, #f5f0e8 100%);
  padding-bottom: calc(200rpx + env(safe-area-inset-bottom));
}

/* 顶部装饰 */
.header-decoration {
  position: relative;
  height: 200rpx;
  overflow: hidden;
}

.decoration-circle {
  position: absolute;
  top: -100rpx;
  right: -100rpx;
  width: 400rpx;
  height: 400rpx;
  background: linear-gradient(135deg, rgba(196, 92, 72, 0.08), rgba(196, 92, 72, 0.02));
  border-radius: 50%;
}

.decoration-line {
  position: absolute;
  bottom: 0;
  left: 40rpx;
  width: 80rpx;
  height: 4rpx;
  background: #6B8E7B;
  border-radius: 2rpx;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 32rpx;
  margin-top: -160rpx;
  position: relative;
  z-index: 10;
}

.nav-back {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 50%;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.nav-icon {
  font-size: 48rpx;
  color: #4a4a4a;
  font-weight: 300;
}

.nav-content {
  flex: 1;
  margin: 0 24rpx;
}

.nav-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 16rpx;
}

.progress-bar {
  height: 6rpx;
  background: #e8e4df;
  border-radius: 3rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #6B8E7B, #8BA89A);
  border-radius: 3rpx;
  transition: width 0.3s ease;
}

.nav-step {
  font-size: 32rpx;
  color: #6B8E7B;
  font-weight: 500;
}

/* 欢迎语 */
.welcome-section {
  padding: 32rpx 48rpx 48rpx;
}

.welcome-title {
  display: block;
  font-size: 52rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
}

.welcome-subtitle {
  display: block;
  font-size: 28rpx;
  color: #8a8a8a;
}

/* 表单卡片 */
.form-card {
  margin: 0 32rpx;
  background: #fff;
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.06);
}

.form-item {
  margin-bottom: 48rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.item-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.item-label {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.item-required {
  font-size: 32rpx;
  color: #6B8E7B;
  margin-left: 8rpx;
}

/* 姓氏输入框 */
.input-box {
  display: flex;
  align-items: center;
  height: 108rpx;
  background: #faf8f5;
  border: 3rpx solid transparent;
  border-radius: 24rpx;
  padding: 0 24rpx;
  transition: all 0.2s ease;
}

.input-box.focus {
  background: #fff;
  border-color: #6B8E7B;
  box-shadow: 0 4rpx 20rpx rgba(196, 92, 72, 0.12);
}

.input-box.has-value {
  background: #fff8f6;
  border-color: #f0d9d4;
}

.surname-input {
  flex: 1;
  height: 100%;
  font-size: 40rpx;
  font-weight: 600;
  color: #1a1a1a;
  text-align: center;
}

.placeholder {
  font-size: 32rpx;
  font-weight: 400;
  color: #b0a8a0;
}

.input-actions {
  display: flex;
  align-items: center;
}

.clear-btn {
  width: 48rpx;
  height: 48rpx;
  background: #e8e4df;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.clear-icon {
  font-size: 32rpx;
  color: #fff;
  font-weight: 300;
}

.input-tip {
  display: block;
  font-size: 24rpx;
  color: #a09890;
  margin-top: 16rpx;
  padding-left: 8rpx;
}

/* 热门姓氏 */
.quick-surnames {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 2rpx dashed #f0ece6;
}

.quick-title {
  display: block;
  font-size: 24rpx;
  color: #a09890;
  margin-bottom: 16rpx;
}

.surname-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.surname-tag {
  padding: 16rpx 32rpx;
  background: #faf8f5;
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #5a524a;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.surname-tag.active {
  background: #fdf2f0;
  border-color: #6B8E7B;
  color: #6B8E7B;
  font-weight: 500;
}

.surname-tag:active {
  transform: scale(0.96);
}

/* 性别选择 */
.gender-group {
  display: flex;
  gap: 32rpx;
}

.gender-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 32rpx;
  background: #faf8f5;
  border: 3rpx solid transparent;
  border-radius: 24rpx;
  position: relative;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}

.gender-option.active {
  background: #fff;
  border-color: #6B8E7B;
  box-shadow: 0 8rpx 32rpx rgba(196, 92, 72, 0.15);
  transform: translateY(-4rpx);
}

.gender-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.gender-icon-wrap.boy {
  background: linear-gradient(135deg, #4a90d9, #7ab8e8);
}

.gender-icon-wrap.girl {
  background: linear-gradient(135deg, #e74c8c, #f08ab0);
}

.gender-symbol {
  font-size: 44rpx;
  color: #fff;
  font-weight: 600;
}

.gender-name {
  font-size: 30rpx;
  color: #4a4a4a;
  font-weight: 500;
}

.gender-option.active .gender-name {
  color: #6B8E7B;
}

.check-icon {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 36rpx;
  height: 36rpx;
  background: #6B8E7B;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #fff;
}

/* 用途选择 */
.purpose-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.purpose-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  background: #faf8f5;
  border: 3rpx solid transparent;
  border-radius: 20rpx;
  transition: all 0.2s;
}

.purpose-item.active {
  background: #fff;
  border-color: #6B8E7B;
  box-shadow: 0 4rpx 20rpx rgba(196, 92, 72, 0.1);
}

.purpose-icon {
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #f5f0e8, #faf8f5);
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 24rpx;
}

.purpose-item.active .purpose-icon {
  background: linear-gradient(135deg, #fdf2f0, #fff);
}

.purpose-info {
  flex: 1;
}

.purpose-name {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.purpose-desc {
  display: block;
  font-size: 24rpx;
  color: #a09890;
}

.purpose-check {
  width: 48rpx;
  height: 48rpx;
  background: #6B8E7B;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #fff;
}

/* 底部区域 */
.footer-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 48rpx calc(48rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(255, 255, 255, 0) 0%, #fff 20%);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.info-badge {
  display: flex;
  align-items: center;
  padding: 16rpx 28rpx;
  background: #fff8e6;
  border-radius: 16rpx;
}

.badge-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.badge-text {
  font-size: 24rpx;
  color: #d48806;
}

.submit-btn {
  display: flex;
  align-items: center;
  padding: 28rpx 48rpx;
  background: #d0d0d0;
  border-radius: 48rpx;
  transition: all 0.3s ease;
}

.submit-btn.active {
  background: linear-gradient(135deg, #6B8E7B, #8BA89A);
  box-shadow: 0 8rpx 32rpx rgba(196, 92, 72, 0.3);
}

.btn-text {
  font-size: 32rpx;
  color: #fff;
  font-weight: 500;
  margin-right: 12rpx;
}

.btn-arrow {
  font-size: 32rpx;
  color: #fff;
}
